{
  "manifest_version": 3,
  "name": "EDS QA Helper",
  "description": "Visual audit & responsive QA tool for Adobe Experience Manager Edge Delivery Services (Franklin)",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "EDS QA Helper"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.hlx.page/*",
    "*://*.hlx.live/*",
    "*://*.aem.page/*",
    "*://*.aem.live/*",
    "http://localhost/*",
    "https://api.figma.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [],
  "web_accessible_resources": [
    {
      "resources": ["content/qa-helper.js"],
      "matches": [
        "*://*.hlx.page/*",
        "*://*.hlx.live/*",
        "*://*.aem.page/*",
        "*://*.aem.live/*",
        "http://localhost/*"
      ]
    }
  ],
  "commands": {
    "toggle-qa-helper": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "Toggle EDS QA Helper"
    }
  }
}
